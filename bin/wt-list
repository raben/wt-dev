#!/usr/bin/env bash
set -euo pipefail

# wt-list: List active worktrees with port and container status

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
WT_DEV_DIR="${WT_DEV_DIR:-$HOME/.wt-dev}"
REGISTRY_FILE="$WT_DEV_DIR/port-registry.json"

usage() {
  cat <<EOF
Usage: wt-list [OPTIONS]

Lists all active worktrees with port and container status.

Options:
  --project-dir DIR   Filter by project
  --json              Output JSON
  -h, --help          Show help
EOF
}

PROJECT_DIR=""
JSON_OUTPUT=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --project-dir) PROJECT_DIR="$2"; shift 2 ;;
    --json)        JSON_OUTPUT=true; shift ;;
    -h|--help)     usage; exit 0 ;;
    *)             echo "Unknown option: $1" >&2; usage; exit 1 ;;
  esac
done

if [ ! -f "$REGISTRY_FILE" ]; then
  echo "No active worktrees."
  exit 0
fi

registry=$(cat "$REGISTRY_FILE")
count=$(echo "$registry" | jq '.allocations | length')

if [ "$count" -eq 0 ]; then
  echo "No active worktrees."
  exit 0
fi

# Filter by project if specified
if [ -n "$PROJECT_DIR" ]; then
  project_name=$(basename "$PROJECT_DIR")
  registry=$(echo "$registry" | jq --arg pn "$project_name" '{
    allocations: (.allocations | to_entries | map(select(.key | startswith($pn + "/"))) | from_entries)
  }')
fi

# Check container status for each worktree
check_container_status() {
  local compose_file="$1/.devcontainer/docker-compose.yml"
  if [ ! -f "$compose_file" ]; then
    echo "no-config"
    return
  fi

  local running
  running=$(docker compose -f "$compose_file" ps --status running -q 2>/dev/null | wc -l | tr -d ' ')
  if [ "$running" -gt 0 ]; then
    echo "running"
  else
    echo "stopped"
  fi
}

if [ "$JSON_OUTPUT" = true ]; then
  # Add status to each entry
  result=$(echo "$registry" | jq '.allocations | to_entries | map({
    key: .key,
    worktree_path: .value.worktree_path,
    project_path: .value.project_path,
    ports: .value.ports,
    created_at: .value.created_at
  })')

  echo "$result" | jq '.'
  exit 0
fi

# Table output
printf "%-25s %-20s %-35s %-10s %s\n" "NAME" "BRANCH" "PORTS" "STATUS" "PATH"
printf "%-25s %-20s %-35s %-10s %s\n" "----" "------" "-----" "------" "----"

echo "$registry" | jq -r '.allocations | to_entries[] | [
  .key,
  .value.worktree_path,
  (.value.ports | to_entries | map("\(.key | gsub("WT_"; "") | gsub("_PORT"; ""))=\(.value)") | join(", "))
] | @tsv' | while IFS=$'\t' read -r key wt_path ports; do
  # Extract branch name (part after /)
  branch="${key#*/}"
  # Check container status
  status=$(check_container_status "$wt_path" 2>/dev/null || echo "unknown")

  printf "%-25s %-20s %-35s %-10s %s\n" "$key" "$branch" "$ports" "$status" "$wt_path"
done
