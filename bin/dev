#!/usr/bin/env bash
set -euo pipefail

# dev - Isolated parallel development environments
# Usage: dev <command> [options]

VERSION="0.7.0"
DEV_STATE_DIR="${DEV_STATE_DIR:-$HOME/.dev-worktree}"
REGISTRY_FILE="$DEV_STATE_DIR/port-registry.json"

# ─── Utilities ───────────────────────────────────────────────

_trim() {
  local s="$1"
  s="${s#"${s%%[![:space:]]*}"}"
  s="${s%"${s##*[![:space:]]}"}"
  printf '%s' "$s"
}

_validate_name() {
  local name="$1"
  if [[ ! "$name" =~ ^[a-zA-Z0-9][a-zA-Z0-9._/-]*$ ]]; then
    echo "ERROR: Invalid name '$name'. Use alphanumeric, dots, hyphens, slashes." >&2
    return 1
  fi
  if [[ "$name" == *".."* ]]; then
    echo "ERROR: Name must not contain '..'." >&2
    return 1
  fi
}

_validate_exec_cmd() {
  local cmd="$1"
  if [[ "$cmd" =~ [\;\|\&\`\$\>\<] ]] || [[ "$cmd" == *'$('* ]] || [[ "$cmd" == *$'\n'* ]]; then
    echo "ERROR: WT_EXEC_CMD contains unsafe characters: $cmd" >&2
    return 1
  fi
}

_with_lock() {
  local lockdir="${REGISTRY_FILE}.lock"
  local max_wait=30 waited=0
  while ! mkdir "$lockdir" 2>/dev/null; do
    sleep 0.1
    waited=$((waited + 1))
    if [ "$waited" -ge "$((max_wait * 10))" ]; then
      echo "ERROR: Could not acquire lock after ${max_wait}s" >&2
      return 1
    fi
  done
  trap 'rmdir "${REGISTRY_FILE}.lock" 2>/dev/null' RETURN
  "$@"
}

_atomic_write() {
  local target="$1"
  local tmpfile
  tmpfile=$(mktemp "${target}.XXXXXX")
  if cat > "$tmpfile" && mv "$tmpfile" "$target"; then
    return 0
  else
    rm -f "$tmpfile"
    return 1
  fi
}

# ─── Port Registry ────────────────────────────────────────────

registry_ensure() {
  mkdir -p "$DEV_STATE_DIR"
  [ -f "$REGISTRY_FILE" ] || echo '{"allocations":{}}' > "$REGISTRY_FILE"
}

port_is_available() {
  ! lsof -i ":${1}" -sTCP:LISTEN &>/dev/null
}

_registry_allocate_impl() {
  local key="$1" env_example="$2" project_path="${3:-}" worktree_path="${4:-}"
  registry_ensure

  local registry
  registry=$(cat "$REGISTRY_FILE")

  if echo "$registry" | jq -e --arg k "$key" '.allocations[$k]' &>/dev/null; then
    echo "ERROR: Ports already allocated for '$key'" >&2
    return 1
  fi

  local used_ports
  used_ports=$(echo "$registry" | jq -r '[.allocations[].ports | to_entries[].value] | .[]' 2>/dev/null || true)

  local ports="{}"
  local non_port_vars="{}"

  while IFS='=' read -r var_name base_value || [ -n "$var_name" ]; do
    [[ -z "$var_name" || "$var_name" =~ ^[[:space:]]*# ]] && continue
    var_name=$(_trim "$var_name")
    base_value=$(_trim "$base_value")

    if [[ "$var_name" =~ _PORT$ ]]; then
      if ! [[ "$base_value" =~ ^[0-9]+$ ]]; then
        echo "ERROR: Invalid port value for $var_name: $base_value" >&2
        return 1
      fi
      local port=$((base_value + 1))
      while true; do
        local conflict=false
        if echo "$used_ports" | grep -qFx "$port" 2>/dev/null; then
          conflict=true
        elif ! port_is_available "$port"; then
          conflict=true
        fi
        [ "$conflict" = false ] && break
        port=$((port + 1))
        if [ "$port" -gt 65535 ]; then
          echo "ERROR: No available port for $var_name (base: $base_value)" >&2
          return 1
        fi
      done
      ports=$(echo "$ports" | jq --arg k "$var_name" --argjson v "$port" '.[$k] = $v')
      used_ports=$(printf '%s\n%d' "$used_ports" "$port")
    else
      non_port_vars=$(echo "$non_port_vars" | jq --arg k "$var_name" --arg v "$base_value" '.[$k] = $v')
    fi
  done < "$env_example"

  local now
  now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  registry=$(echo "$registry" | jq \
    --arg key "$key" --argjson ports "$ports" --argjson vars "$non_port_vars" \
    --arg time "$now" --arg pp "$project_path" --arg wp "$worktree_path" \
    '.allocations[$key] = {ports: $ports, vars: $vars, project_path: $pp, worktree_path: $wp, created_at: $time}')
  echo "$registry" | jq '.' | _atomic_write "$REGISTRY_FILE"

  echo "$ports" | jq -r 'to_entries[] | "\(.key)=\(.value)"'
  echo "$non_port_vars" | jq -r 'to_entries[] | "\(.key)=\(.value)"'
}

registry_allocate() {
  _with_lock _registry_allocate_impl "$@"
}

_registry_release_impl() {
  local key="$1"
  registry_ensure
  local registry
  registry=$(cat "$REGISTRY_FILE")
  if ! echo "$registry" | jq -e --arg k "$key" '.allocations[$k]' &>/dev/null; then
    return 0
  fi
  echo "$registry" | jq --arg k "$key" 'del(.allocations[$k])' | _atomic_write "$REGISTRY_FILE"
}

registry_release() {
  _with_lock _registry_release_impl "$@"
}

# ─── dev up ─────────────────────────────────────────────────────

cmd_up() {
  local project_dir="" name="" base_branch="main"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --project-dir) project_dir="$2"; shift 2 ;;
      -h|--help)
        cat <<EOF
Usage: dev up [OPTIONS] [name] [base-branch]

Create (or resume) a worktree and start its devcontainer.

Arguments:
  name          Worktree / branch name (auto-generated if omitted)
  base-branch   Base branch (default: main)

Options:
  --project-dir DIR   Project root (default: git root of CWD)
EOF
        return 0 ;;
      -*) echo "Unknown option: $1" >&2; return 1 ;;
      *)  [ -z "$name" ] && name="$1" || base_branch="$1"; shift ;;
    esac
  done

  [ -z "$name" ] && name="wt-$(head -c 4 /dev/urandom | xxd -p)"
  _validate_name "$name"

  if [ -z "$project_dir" ]; then
    project_dir=$(git rev-parse --show-toplevel 2>/dev/null || true)
    [ -z "$project_dir" ] && { echo "ERROR: Not in a git repo. Use --project-dir." >&2; return 1; }
  fi

  local project_name
  project_name=$(basename "$project_dir")
  local worktree_dir
  worktree_dir="$(dirname "$project_dir")/${project_name}-${name}"
  local registry_key="${project_name}/${name}"

  if ! command -v devcontainer &>/dev/null; then
    echo "ERROR: devcontainer CLI not found. Install: npm install -g @devcontainers/cli" >&2
    return 1
  fi

  # ── Existing worktree: resume ──
  if [ -d "$worktree_dir" ]; then
    echo "Worktree '$name' already exists at $worktree_dir"

    local compose_file="$worktree_dir/.devcontainer/docker-compose.yml"
    if [ -f "$compose_file" ]; then
      local running
      running=$(docker compose -f "$compose_file" ps --status running -q 2>/dev/null | wc -l | tr -d ' ')
      if [ "$running" -gt 0 ]; then
        echo "Container already running."
      else
        echo "Starting devcontainer..."
        devcontainer up --workspace-folder "$worktree_dir"
      fi
    else
      echo "Starting devcontainer..."
      devcontainer up --workspace-folder "$worktree_dir"
    fi

    echo ""
    echo "Ready. Use 'dev open' to connect."
    return
  fi

  # ── New worktree: create ──
  local _cleanup_enabled=true

  cleanup() {
    local ec=$?
    if [ $ec -ne 0 ] && [ "$_cleanup_enabled" = true ]; then
      echo "ERROR: Failed. Cleaning up..."
      [ -d "$worktree_dir/.devcontainer" ] && docker compose -f "$worktree_dir/.devcontainer/docker-compose.yml" down -v 2>/dev/null || true
      [ -d "$worktree_dir" ] && git -C "$project_dir" worktree remove --force "$worktree_dir" 2>/dev/null || true
      git -C "$project_dir" branch -D "$name" 2>/dev/null || true
      registry_release "$registry_key" 2>/dev/null || true
    fi
  }
  trap cleanup EXIT

  [ ! -d "$project_dir/.devcontainer" ] && { echo "ERROR: No .devcontainer/ in $project_dir"; return 1; }

  # Allocate ports
  local env_example="$project_dir/.devcontainer/.env.example"
  local allocated_vars=""
  if [ -f "$env_example" ]; then
    echo "Allocating ports..."
    allocated_vars=$(registry_allocate "$registry_key" "$env_example" "$project_dir" "$worktree_dir")
  fi

  # Create worktree
  echo "Creating worktree..."
  git -C "$project_dir" worktree add "$worktree_dir" -b "$name" -- "$base_branch"

  # Copy and configure .devcontainer
  echo "Setting up devcontainer..."
  cp -r "$project_dir/.devcontainer" "$worktree_dir/.devcontainer"

  if [ -n "$allocated_vars" ]; then
    allocated_vars=$(printf '%s\nWT_NAME=%s\nCOMPOSE_PROJECT_NAME=%s' \
      "$allocated_vars" "${project_name}-${name}" "${project_name}-${name}")

    echo "$allocated_vars" > "$worktree_dir/.devcontainer/.env"

    local compose_file="$worktree_dir/.devcontainer/docker-compose.yml"
    if [ -f "$compose_file" ]; then
      while IFS='=' read -r key val; do
        [ -z "$key" ] && continue
        local escaped_val
        escaped_val=$(printf '%s\n' "$val" | sed 's/[&/|\\]/\\&/g')
        sed "s|\${${key}:-[^}]*}|${escaped_val}|g" "$compose_file" > "${compose_file}.tmp" && mv "${compose_file}.tmp" "$compose_file"
        sed "s|\${${key}}|${escaped_val}|g" "$compose_file" > "${compose_file}.tmp" && mv "${compose_file}.tmp" "$compose_file"
      done <<< "$allocated_vars"
    fi

    local dc_json="$worktree_dir/.devcontainer/devcontainer.json"
    if [ -f "$dc_json" ] && command -v jq &>/dev/null; then
      jq --arg n "${project_name}-${name}" '.name = $n' "$dc_json" > "${dc_json}.tmp" && mv "${dc_json}.tmp" "$dc_json"
    fi
  fi

  # Start devcontainer
  echo "Starting devcontainer..."
  devcontainer up --workspace-folder "$worktree_dir"

  # Disable cleanup — worktree created successfully
  _cleanup_enabled=false
  trap - EXIT

  # Summary
  echo ""
  echo "=== Worktree created ==="
  echo "  Path:   $worktree_dir"
  echo "  Branch: $name"
  if [ -n "$allocated_vars" ]; then
    echo "  Ports:"
    echo "$allocated_vars" | { grep '_PORT=' || true; } | while IFS='=' read -r k v; do echo "    $k: $v"; done
  fi
  echo ""
  echo "Ready. Use 'dev open' to connect."
}

# ─── dev down ───────────────────────────────────────────────────

# Resolve worktree name ↔ path from arguments
_resolve_worktree() {
  local _project_dir="$1" _name="$2" _worktree_path="$3"
  local _project_name=""
  [ -n "$_project_dir" ] && _project_name=$(basename "$_project_dir")

  if [ -n "$_worktree_path" ] && [ -z "$_name" ]; then
    local bn
    bn=$(basename "$_worktree_path")
    if [ -n "$_project_name" ] && [[ "$bn" == "${_project_name}-"* ]]; then
      _name="${bn#${_project_name}-}"
    else
      _name="$bn"
    fi
  elif [ -n "$_name" ] && [ -z "$_worktree_path" ]; then
    [ -n "$_project_dir" ] && _worktree_path="$(dirname "$_project_dir")/${_project_name}-${_name}"
  fi

  echo "$_name"$'\t'"$_worktree_path"$'\t'"$_project_name"
}

cmd_down() {
  local project_dir="" name="" worktree_path=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --project-dir) project_dir="$2"; shift 2 ;;
      --path)        worktree_path="$2"; shift 2 ;;
      -h|--help)
        cat <<EOF
Usage: dev down [OPTIONS] <name>

Stop devcontainer (worktree and ports are kept).

Options:
  --project-dir DIR   Project root (default: git root of CWD)
  --path PATH         Worktree path (alternative to name)
EOF
        return 0 ;;
      -*) echo "Unknown option: $1" >&2; return 1 ;;
      *)  name="$1"; shift ;;
    esac
  done

  [ -z "$project_dir" ] && project_dir=$(git rev-parse --show-toplevel 2>/dev/null || true)

  local resolved
  resolved=$(_resolve_worktree "$project_dir" "$name" "$worktree_path")
  IFS=$'\t' read -r name worktree_path _ <<< "$resolved"

  [ -z "$name" ] && [ -z "$worktree_path" ] && { echo "ERROR: Name or --path required" >&2; return 1; }

  echo "Stopping '$name'..."

  local compose_file="$worktree_path/.devcontainer/docker-compose.yml"
  if [ -f "$compose_file" ]; then
    docker compose -f "$compose_file" down 2>/dev/null || true
  else
    echo "No compose file found at $worktree_path" >&2
  fi

  echo "Done. Worktree kept at $worktree_path"
}

# ─── dev prune ─────────────────────────────────────────────────

cmd_prune() {
  local project_dir="" name="" worktree_path="" force=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --project-dir) project_dir="$2"; shift 2 ;;
      --path)        worktree_path="$2"; shift 2 ;;
      --force|-f)    force=true; shift ;;
      -h|--help)
        cat <<EOF
Usage: dev prune [OPTIONS] <name>

Remove worktree, containers, branch, and release ports.

Options:
  --project-dir DIR   Project root (default: git root of CWD)
  --path PATH         Worktree path (alternative to name)
  --force, -f         Skip uncommitted changes check
EOF
        return 0 ;;
      -*) echo "Unknown option: $1" >&2; return 1 ;;
      *)  name="$1"; shift ;;
    esac
  done

  [ -z "$project_dir" ] && project_dir=$(git rev-parse --show-toplevel 2>/dev/null || true)

  local resolved project_name
  resolved=$(_resolve_worktree "$project_dir" "$name" "$worktree_path")
  IFS=$'\t' read -r name worktree_path project_name <<< "$resolved"

  [ -z "$name" ] && [ -z "$worktree_path" ] && { echo "ERROR: Name or --path required" >&2; return 1; }

  local registry_key="${project_name}/${name}"
  echo "Removing '$name'..."

  # Check uncommitted changes
  if [ -d "$worktree_path" ] && [ "$force" = false ]; then
    if ! git -C "$worktree_path" diff --quiet 2>/dev/null || \
       ! git -C "$worktree_path" diff --cached --quiet 2>/dev/null; then
      echo "WARNING: Uncommitted changes in $worktree_path"
      if [ -t 0 ]; then
        read -rp "Continue? (y/N) " confirm
        [[ "$confirm" != [yY]* ]] && { echo "Aborted."; return 1; }
      else
        echo "Use --force to skip." >&2; return 1
      fi
    fi
  fi

  # Stop and remove containers + volumes
  local compose_file="$worktree_path/.devcontainer/docker-compose.yml"
  [ -f "$compose_file" ] && { echo "Stopping containers..."; docker compose -f "$compose_file" down -v 2>/dev/null || true; }

  # Remove worktree
  if [ -d "$worktree_path" ]; then
    echo "Removing worktree..."
    if [ "$force" = true ]; then
      git -C "$project_dir" worktree remove --force "$worktree_path" 2>/dev/null || true
    else
      git -C "$project_dir" worktree remove "$worktree_path" 2>/dev/null || true
    fi
  fi
  git -C "$project_dir" worktree prune 2>/dev/null || true

  # Delete branch if merged
  if [ -n "$name" ] && [ -n "$project_dir" ]; then
    if git -C "$project_dir" branch -d "$name" 2>/dev/null; then
      echo "Branch '$name' deleted (merged)."
    else
      echo "Branch '$name' kept (not merged). Use: git branch -D $name"
    fi
  fi

  # Release ports
  registry_release "$registry_key" 2>/dev/null || true
  echo "Done."
}

# ─── dev list ──────────────────────────────────────────────────

cmd_list() {
  local project_dir="" json_output=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --project-dir) project_dir="$2"; shift 2 ;;
      --json)        json_output=true; shift ;;
      -h|--help)
        cat <<EOF
Usage: dev list [OPTIONS]

List active worktrees with port and container status.

Options:
  --project-dir DIR   Filter by project
  --json              Output JSON
EOF
        return 0 ;;
      *) echo "Unknown option: $1" >&2; return 1 ;;
    esac
  done

  registry_ensure
  local registry
  registry=$(cat "$REGISTRY_FILE")
  local count
  count=$(echo "$registry" | jq '.allocations | length')

  if [ "$count" -eq 0 ]; then
    echo "No active worktrees."
    return 0
  fi

  if [ -n "$project_dir" ]; then
    local pn
    pn=$(basename "$project_dir")
    registry=$(echo "$registry" | jq --arg pn "$pn" '{
      allocations: (.allocations | to_entries | map(select(.key | startswith($pn + "/"))) | from_entries)
    }')
  fi

  if [ "$json_output" = true ]; then
    echo "$registry" | jq '.allocations'
    return 0
  fi

  printf "%-25s %-20s %-35s %-10s %s\n" "NAME" "BRANCH" "PORTS" "STATUS" "PATH"
  printf "%-25s %-20s %-35s %-10s %s\n" "----" "------" "-----" "------" "----"

  echo "$registry" | jq -r '.allocations | to_entries[] | [
    .key,
    .value.worktree_path,
    (.value.ports | to_entries | map("\(.key | gsub("WT_";"") | gsub("_PORT";""))=\(.value)") | join(", "))
  ] | @tsv' | while IFS=$'\t' read -r key wt_path ports; do
    local branch="${key#*/}"
    local status="unknown"
    local cf="$wt_path/.devcontainer/docker-compose.yml"
    if [ -f "$cf" ]; then
      local running
      running=$(docker compose -f "$cf" ps --status running -q 2>/dev/null | wc -l | tr -d ' ')
      [ "$running" -gt 0 ] && status="running" || status="stopped"
    fi
    printf "%-25s %-20s %-35s %-10s %s\n" "$key" "$branch" "$ports" "$status" "$wt_path"
  done
}

# ─── dev ports ─────────────────────────────────────────────────

cmd_ports() {
  local subcmd="${1:-list}"
  shift 2>/dev/null || true

  case "$subcmd" in
    allocate)     registry_allocate "$@" ;;
    release)      registry_release "$@" && echo "Released." ;;
    get)
      local key="${1:?Usage: dev ports get <key>}"
      registry_ensure
      jq -r --arg k "$key" '.allocations[$k].ports | to_entries[] | "\(.key)=\(.value)"' "$REGISTRY_FILE"
      ;;
    find-by-path)
      local path="${1:?Usage: dev ports find-by-path <path>}"
      registry_ensure
      jq -r --arg p "$path" '.allocations | to_entries[] | select(.value.worktree_path == $p) | .key' "$REGISTRY_FILE"
      ;;
    list)
      registry_ensure
      local count
      count=$(jq '.allocations | length' "$REGISTRY_FILE")
      if [ "$count" -eq 0 ]; then echo "No allocations."; return 0; fi
      printf "%-30s %-40s %s\n" "KEY" "WORKTREE PATH" "PORTS"
      printf "%-30s %-40s %s\n" "---" "-------------" "-----"
      jq -r '.allocations | to_entries[] | [
        .key, .value.worktree_path,
        (.value.ports | to_entries | map("\(.key)=\(.value)") | join(", "))
      ] | @tsv' "$REGISTRY_FILE" | while IFS=$'\t' read -r key wt_path ports; do
        printf "%-30s %-40s %s\n" "$key" "$wt_path" "$ports"
      done
      ;;
    -h|--help)
      cat <<EOF
Usage: dev ports <command> [args]

Commands:
  list                          List all port allocations
  get <key>                     Show ports for a worktree
  allocate <key> <env-example>  Allocate ports
  release <key>                 Release ports
  find-by-path <path>           Find key by worktree path
EOF
      ;;
    *) echo "Unknown ports command: $subcmd" >&2; return 1 ;;
  esac
}

# ─── dev open ─────────────────────────────────────────────────

_container_is_running() {
  local wt_path="$1"
  local compose_file="$wt_path/.devcontainer/docker-compose.yml"
  [ -f "$compose_file" ] || return 1
  local running
  running=$(docker compose -f "$compose_file" ps --status running -q 2>/dev/null | wc -l | tr -d ' ')
  [ "$running" -gt 0 ]
}

# Get WT_EXEC_CMD for a registry key (fallback: claude)
_get_exec_cmd() {
  local key="$1"
  local cmd
  cmd=$(jq -r --arg k "$key" '.allocations[$k].vars.WT_EXEC_CMD // empty' "$REGISTRY_FILE" 2>/dev/null)
  if [ -z "$cmd" ]; then
    cmd="claude --dangerously-skip-permissions"
  fi
  _validate_exec_cmd "$cmd"
  echo "$cmd"
}

_watcher() {
  trap 'exit 0' SIGTERM SIGINT
  local session="$1" filter="${2:-}"

  while true; do
    # ── Live status display ──
    tput clear 2>/dev/null || clear
    echo "dev-worktree dashboard  (poll: 3s)"
    echo ""

    registry_ensure
    local registry
    registry=$(cat "$REGISTRY_FILE")
    local keys
    keys=$(jq -r '.allocations | keys[]' "$REGISTRY_FILE" 2>/dev/null || true)

    local count
    count=$(echo "$registry" | jq '.allocations | length')

    if [ "$count" -eq 0 ]; then
      echo "No environments. Run 'dev up <name>' in another terminal."
    else
      printf "  %-25s %-10s %s\n" "NAME" "STATUS" "PORTS"
      printf "  %-25s %-10s %s\n" "----" "------" "-----"

      while IFS= read -r key; do
        [ -z "$key" ] && continue
        local wt_path
        wt_path=$(echo "$registry" | jq -r --arg k "$key" '.allocations[$k].worktree_path')
        local ports
        ports=$(echo "$registry" | jq -r --arg k "$key" '.allocations[$k].ports | to_entries | map("\(.key | gsub("WT_";"") | gsub("_PORT";""))=\(.value)") | join(", ")' 2>/dev/null || true)

        local status="stopped"
        _container_is_running "$wt_path" && status="running"

        printf "  %-25s %-10s %s\n" "$key" "$status" "$ports"
      done <<< "$keys"
    fi

    echo ""
    echo "Ctrl+B then arrow keys to switch panes. Ctrl+B D to detach."

    # ── Detect and add new panes ──
    local existing_titles
    existing_titles=$(tmux list-panes -t "$session" -F '#{pane_title}' 2>/dev/null || true)

    while IFS= read -r key; do
      [ -z "$key" ] && continue
      [ -n "$filter" ] && [[ "$key" != *"$filter"* ]] && continue

      echo "$existing_titles" | grep -qFx "$key" && continue

      local wt_path
      wt_path=$(jq -r --arg k "$key" '.allocations[$k].worktree_path' "$REGISTRY_FILE" 2>/dev/null)
      [ -z "$wt_path" ] || [ "$wt_path" = "null" ] && continue

      _container_is_running "$wt_path" || continue

      local exec_cmd
      exec_cmd=$(_get_exec_cmd "$key")

      # Use env vars to avoid command injection
      tmux split-window -t "$session" -e "DEV_KEY=$key" -e "DEV_WT_PATH=$wt_path" -e "DEV_EXEC_CMD=$exec_cmd" \
        'printf "\033]2;${DEV_KEY}\033\\"; devcontainer exec --workspace-folder "${DEV_WT_PATH}" ${DEV_EXEC_CMD}; echo "--- Session ended (${DEV_KEY}). Press Enter to close. ---"; read'
      tmux select-pane -T "$key"
      tmux select-layout -t "$session" tiled
    done <<< "$keys"

    sleep 3
  done
}

cmd_open() {
  local name=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)
        cat <<EOF
Usage: dev open [name]

Open AI coding sessions in a tmux dashboard.

Without arguments: opens all running environments in split panes
with live detection of new environments.

With a name: directly connects to a single environment (no tmux).

The command executed is determined by WT_EXEC_CMD in .env.example
(default: claude --dangerously-skip-permissions).

Requires 'tmux' for dashboard mode.
EOF
        return 0 ;;
      -*) echo "Unknown option: $1" >&2; return 1 ;;
      *)  name="$1"; shift ;;
    esac
  done

  # ── Single session mode ──
  if [ -n "$name" ]; then
    local project_dir
    project_dir=$(git rev-parse --show-toplevel 2>/dev/null || true)
    [ -z "$project_dir" ] && { echo "ERROR: Not in a git repo." >&2; return 1; }

    local project_name
    project_name=$(basename "$project_dir")
    local worktree_dir
    worktree_dir="$(dirname "$project_dir")/${project_name}-${name}"

    [ ! -d "$worktree_dir" ] && { echo "ERROR: Worktree '$name' not found at $worktree_dir" >&2; return 1; }

    _container_is_running "$worktree_dir" || { echo "ERROR: Container not running. Run 'dev up $name' first." >&2; return 1; }

    local registry_key="${project_name}/${name}"
    local exec_cmd
    exec_cmd=$(_get_exec_cmd "$registry_key")

    devcontainer exec --workspace-folder "$worktree_dir" $exec_cmd
    return
  fi

  # ── Dashboard mode ──
  if ! command -v tmux &>/dev/null; then
    echo "ERROR: tmux required for dashboard mode. Install: brew install tmux" >&2
    return 1
  fi

  local session="dev"
  local dev_cmd
  dev_cmd=$(realpath "$0" 2>/dev/null || echo "$0")

  # Kill stale session
  tmux kill-session -t "$session" 2>/dev/null || true

  # Start tmux with watcher in first pane
  tmux new-session -d -s "$session" -n "dev" \
    -e "DEV_CMD=$dev_cmd" -e "DEV_SESSION=$session" \
    '"${DEV_CMD}" _watcher "${DEV_SESSION}"'
  tmux select-pane -t "$session" -T "_dashboard"

  tmux attach-session -t "$session"
}

# ─── dev init ─────────────────────────────────────────────────

INIT_PROMPT='You are setting up a devcontainer for the `dev` CLI tool (dev-worktree).

## Step 1: Project validation

First, analyze the current directory and determine:
- Is this a software development project? (look for package.json, go.mod, Cargo.toml, requirements.txt, pyproject.toml, Makefile, src/, etc.)
- What language/runtime does it use?
- What services does it depend on? (databases, caches, emulators, etc.)
- Does `.devcontainer/` already exist?

Present your findings as a brief summary and ask the user to confirm before proceeding.
Example:
  "Node.js (pnpm) + Spanner emulator. Ports: MCP 3000, Web 3001, Spanner 9010/9020. Proceed?"

If this does NOT look like a development project (no recognizable project files), tell the user and stop.
If `.devcontainer/` already exists, show what is there and ask if they want to overwrite.

## Step 2: Generate files

After user confirmation, generate:

1. `.devcontainer/Dockerfile`
2. `.devcontainer/devcontainer.json`
3. `.devcontainer/docker-compose.yml`
4. `.devcontainer/.env.example`

## Conventions (MUST follow)

### Dockerfile
- Base image: use the appropriate `mcr.microsoft.com/devcontainers/*` image
- Install: git, jq, curl
- If $DEV_EXEC_CMD contains "claude", install Claude Code: `npm install -g @anthropic-ai/claude-code`
- Install project-specific package manager if needed (pnpm, yarn, etc.)
- Non-root user (node for Node.js, vscode for others)
- WORKDIR /workspace

### devcontainer.json
- `"name"`: project directory name
- `"dockerComposeFile"`: "docker-compose.yml"
- `"service"`: "app"
- `"workspaceFolder"`: "/workspace"
- `"remoteUser"`: appropriate non-root user
- `"mounts"`: bind mount `~/.gitconfig` (readonly). If $DEV_EXEC_CMD contains "claude", also mount `~/.claude` (for auth)
- `"containerEnv"`: if $DEV_EXEC_CMD contains "claude", set `CLAUDE_CONFIG_DIR` to the mounted .claude path
- `"postCreateCommand"`: appropriate install command (npm ci, pnpm install, pip install, etc.)

### docker-compose.yml
- Use `${WT_NAME:-<project-name>}` in all `container_name:` fields
- Use `${COMPOSE_PROJECT_NAME:-<project-name>}` or rely on docker compose default
- Use `${WT_<SERVICE>_PORT:-<default>}:<container-port>` for ALL port mappings
- App service: `command: sleep infinity` (Claude Code starts services as needed)
- App service: mount `..:/workspace:cached` and a named volume for node_modules/venv/etc.
- Include all dependent services the project needs (database, cache, emulators, etc.)

### .env.example
- Header comment explaining the format
- `WT_NAME=<project-name>`
- `COMPOSE_PROJECT_NAME=<project-name>`
- `WT_EXEC_CMD=<exec-command>` (the AI CLI command to run in `dev open`; use the value from $DEV_EXEC_CMD if set, otherwise `claude --dangerously-skip-permissions`)
- One `WT_<SERVICE>_PORT=<default-port>` line per port mapping in docker-compose.yml
- Variables ending in `_PORT` are auto-allocated by `dev up`; others are passed through

## Important
- Do NOT add unnecessary services. Only include what the project actually uses.
- Do NOT modify any existing project files. Only create files in `.devcontainer/`.
- If `.devcontainer/` already exists, ask before overwriting.'

cmd_init() {
  local exec_cmd="" ai_cmd=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --exec-cmd) exec_cmd="$2"; shift 2 ;;
      --ai-cmd)   ai_cmd="$2"; shift 2 ;;
      -h|--help)
        cat <<EOF
Usage: dev init [OPTIONS]

Generate .devcontainer/ for the current project using an AI CLI.
Defaults to Claude.

Options:
  --ai-cmd CMD     AI CLI command (default: claude)
  --exec-cmd CMD   Command for 'dev open' sessions (default: claude --dangerously-skip-permissions)
EOF
        return 0 ;;
      *) echo "Unknown option: $1" >&2; return 1 ;;
    esac
  done

  [ -z "$ai_cmd" ] && ai_cmd="claude"

  if ! command -v "${ai_cmd%% *}" &>/dev/null; then
    echo "ERROR: '${ai_cmd%% *}' not found. Install it or use --ai-cmd to specify another CLI." >&2
    return 1
  fi

  # WT_EXEC_CMD default: match ai_cmd
  if [ -z "$exec_cmd" ]; then
    case "$ai_cmd" in
      claude) exec_cmd="claude --dangerously-skip-permissions" ;;
      *)      exec_cmd="$ai_cmd" ;;
    esac
  fi
  _validate_exec_cmd "$exec_cmd"

  echo "Generating .devcontainer/ with ${ai_cmd%% *} ..."
  DEV_EXEC_CMD="$exec_cmd" $ai_cmd "$INIT_PROMPT"
}

# ─── Main ─────────────────────────────────────────────────────

usage() {
  cat <<EOF
dev $VERSION - Isolated parallel development environments

Usage: dev <command> [options]

Commands:
  init               Generate .devcontainer/ for this project
  up [name] [base]   Create (or resume) worktree + devcontainer
  open [name]        Open AI coding sessions (tmux dashboard)
  down <name>        Stop devcontainer (worktree kept)
  prune <name>       Remove worktree, containers, branch, ports
  list               Show active worktrees
  ports              Manage port allocations

Run 'dev <command> --help' for details.
EOF
}

case "${1:-}" in
  init)     shift; cmd_init "$@" ;;
  up)       shift; cmd_up "$@" ;;
  open)     shift; cmd_open "$@" ;;
  down)     shift; cmd_down "$@" ;;
  prune)    shift; cmd_prune "$@" ;;
  list|ls)  shift; cmd_list "$@" ;;
  ports)    shift; cmd_ports "$@" ;;
  _watcher) shift; _watcher "$@" ;;
  -v|--version) echo "dev $VERSION" ;;
  -h|--help|"") usage ;;
  *)      echo "Unknown command: $1" >&2; usage; exit 1 ;;
esac
