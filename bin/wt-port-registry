#!/usr/bin/env bash
set -euo pipefail

# wt-port-registry: Port allocation manager for wt-dev
# State: ~/.wt-dev/port-registry.json

WT_DEV_DIR="${WT_DEV_DIR:-$HOME/.wt-dev}"
REGISTRY_FILE="$WT_DEV_DIR/port-registry.json"

ensure_registry() {
  mkdir -p "$WT_DEV_DIR"
  if [ ! -f "$REGISTRY_FILE" ]; then
    echo '{"allocations":{}}' > "$REGISTRY_FILE"
  fi
}

# Check if a port is available on the host
is_port_available() {
  local port=$1
  ! lsof -i ":${port}" -sTCP:LISTEN &>/dev/null
}

# Allocate ports for a worktree
# Usage: wt-port-registry allocate <key> <env-example-path> [project-path] [worktree-path]
cmd_allocate() {
  local key="${1:?Usage: wt-port-registry allocate <key> <env-example-path> [project-path] [worktree-path]}"
  local env_example="${2:?Missing .env.example path}"
  local project_path="${3:-}"
  local worktree_path="${4:-}"

  ensure_registry

  local registry
  registry=$(cat "$REGISTRY_FILE")

  # Check if already allocated
  if echo "$registry" | jq -e ".allocations[\"$key\"]" &>/dev/null; then
    echo "ERROR: Ports already allocated for '$key'" >&2
    return 1
  fi

  # Collect all currently allocated ports
  local used_ports
  used_ports=$(echo "$registry" | jq -r '[.allocations[].ports | to_entries[].value] | .[]' 2>/dev/null || true)

  # Parse .env.example and allocate ports
  local ports="{}"
  local non_port_vars="{}"

  while IFS='=' read -r var_name base_value || [ -n "$var_name" ]; do
    # Skip comments and empty lines
    [[ -z "$var_name" || "$var_name" =~ ^[[:space:]]*# ]] && continue
    # Trim whitespace
    var_name=$(echo "$var_name" | xargs)
    base_value=$(echo "$base_value" | xargs)

    if [[ "$var_name" =~ _PORT$ ]]; then
      # Port variable: allocate next available
      local port=$((base_value + 1))
      while true; do
        local conflict=false
        if echo "$used_ports" | grep -q "^${port}$" 2>/dev/null; then
          conflict=true
        elif ! is_port_available "$port"; then
          conflict=true
        fi

        if [ "$conflict" = false ]; then
          break
        fi

        port=$((port + 1))
        if [ "$port" -gt 65535 ]; then
          echo "ERROR: No available port for $var_name (base: $base_value)" >&2
          return 1
        fi
      done

      ports=$(echo "$ports" | jq --arg k "$var_name" --argjson v "$port" '.[$k] = $v')
      # Track this port as used for subsequent allocations
      used_ports=$(printf '%s\n%d' "$used_ports" "$port")
    else
      # Non-port variable: store as-is
      non_port_vars=$(echo "$non_port_vars" | jq --arg k "$var_name" --arg v "$base_value" '.[$k] = $v')
    fi
  done < "$env_example"

  # Record in registry
  local now
  now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

  registry=$(echo "$registry" | jq \
    --arg key "$key" \
    --argjson ports "$ports" \
    --argjson vars "$non_port_vars" \
    --arg time "$now" \
    --arg pp "$project_path" \
    --arg wp "$worktree_path" \
    '.allocations[$key] = {
      ports: $ports,
      vars: $vars,
      project_path: $pp,
      worktree_path: $wp,
      created_at: $time
    }')

  echo "$registry" | jq '.' > "$REGISTRY_FILE"

  # Output the allocated ports and vars as KEY=VALUE
  echo "$ports" | jq -r 'to_entries[] | "\(.key)=\(.value)"'
  echo "$non_port_vars" | jq -r 'to_entries[] | "\(.key)=\(.value)"'
}

# Release ports for a worktree
# Usage: wt-port-registry release <key>
cmd_release() {
  local key="${1:?Usage: wt-port-registry release <key>}"
  ensure_registry

  local registry
  registry=$(cat "$REGISTRY_FILE")

  if ! echo "$registry" | jq -e ".allocations[\"$key\"]" &>/dev/null; then
    echo "WARN: No allocation found for '$key'" >&2
    return 0
  fi

  registry=$(echo "$registry" | jq --arg key "$key" 'del(.allocations[$key])')
  echo "$registry" | jq '.' > "$REGISTRY_FILE"
  echo "Released ports for '$key'"
}

# Get ports for a worktree
# Usage: wt-port-registry get <key>
cmd_get() {
  local key="${1:?Usage: wt-port-registry get <key>}"
  ensure_registry

  local registry
  registry=$(cat "$REGISTRY_FILE")

  if ! echo "$registry" | jq -e ".allocations[\"$key\"]" &>/dev/null; then
    echo "ERROR: No allocation found for '$key'" >&2
    return 1
  fi

  echo "$registry" | jq -r ".allocations[\"$key\"].ports | to_entries[] | \"\(.key)=\(.value)\""
}

# Find key by worktree path
# Usage: wt-port-registry find-by-path <worktree-path>
cmd_find_by_path() {
  local path="${1:?Usage: wt-port-registry find-by-path <worktree-path>}"
  ensure_registry

  local key
  key=$(jq -r --arg p "$path" '.allocations | to_entries[] | select(.value.worktree_path == $p) | .key' "$REGISTRY_FILE")

  if [ -z "$key" ]; then
    echo "ERROR: No allocation found for path '$path'" >&2
    return 1
  fi

  echo "$key"
}

# List all allocations
cmd_list() {
  ensure_registry

  local registry
  registry=$(cat "$REGISTRY_FILE")
  local count
  count=$(echo "$registry" | jq '.allocations | length')

  if [ "$count" -eq 0 ]; then
    echo "No active allocations."
    return 0
  fi

  if [ "${1:-}" = "--json" ]; then
    echo "$registry" | jq '.allocations'
    return 0
  fi

  # Table format
  printf "%-30s %-40s %s\n" "KEY" "WORKTREE PATH" "PORTS"
  printf "%-30s %-40s %s\n" "---" "-------------" "-----"

  echo "$registry" | jq -r '.allocations | to_entries[] | [
    .key,
    .value.worktree_path,
    (.value.ports | to_entries | map("\(.key)=\(.value)") | join(", "))
  ] | @tsv' | while IFS=$'\t' read -r key wt_path ports; do
    printf "%-30s %-40s %s\n" "$key" "$wt_path" "$ports"
  done
}

# Main dispatcher
usage() {
  cat <<EOF
Usage: wt-port-registry <command> [args]

Commands:
  allocate <key> <env-example>  Allocate ports for a worktree
  release <key>                 Release ports
  get <key>                     Get ports for a worktree
  find-by-path <path>           Find key by worktree path
  list [--json]                 List all allocations

State: $REGISTRY_FILE
EOF
}

case "${1:-}" in
  allocate)    shift; cmd_allocate "$@" ;;
  release)     shift; cmd_release "$@" ;;
  get)         shift; cmd_get "$@" ;;
  find-by-path) shift; cmd_find_by_path "$@" ;;
  list)        shift; cmd_list "$@" ;;
  -h|--help|"") usage ;;
  *)           echo "Unknown command: $1" >&2; usage; exit 1 ;;
esac
