#!/usr/bin/env bash
set -euo pipefail

# wt-create: Create a git worktree and start its devcontainer
# Supports both CLI args and Claude Code hook mode (stdin JSON)

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

usage() {
  cat <<EOF
Usage: wt-create [OPTIONS] <name> [base-branch]

Creates a git worktree with an independent devcontainer.

Arguments:
  name          Worktree name (also used as branch name)
  base-branch   Base branch (default: main)

Options:
  --project-dir DIR   Project root (default: git root of CWD)
  --hook              Read parameters from JSON stdin (Claude Code hook mode)
  -h, --help          Show help

Examples:
  wt-create feature-auth
  wt-create feature-auth develop
  wt-create --project-dir /path/to/project feature-auth
EOF
}

# Parse arguments
HOOK_MODE=false
PROJECT_DIR=""
NAME=""
BASE_BRANCH="main"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --hook)       HOOK_MODE=true; shift ;;
    --project-dir) PROJECT_DIR="$2"; shift 2 ;;
    -h|--help)    usage; exit 0 ;;
    -*)           echo "Unknown option: $1" >&2; usage; exit 1 ;;
    *)
      if [ -z "$NAME" ]; then
        NAME="$1"
      else
        BASE_BRANCH="$1"
      fi
      shift
      ;;
  esac
done

# Hook mode: read from stdin
if [ "$HOOK_MODE" = true ]; then
  INPUT=$(cat)
  NAME=$(echo "$INPUT" | jq -r '.name // empty')
  HOOK_CWD=$(echo "$INPUT" | jq -r '.cwd // empty')
  if [ -z "$PROJECT_DIR" ] && [ -n "$HOOK_CWD" ]; then
    PROJECT_DIR="$HOOK_CWD"
  fi
fi

if [ -z "$NAME" ]; then
  echo "ERROR: Worktree name is required" >&2
  usage >&2
  exit 1
fi

# Determine project root
if [ -z "$PROJECT_DIR" ]; then
  PROJECT_DIR=$(git rev-parse --show-toplevel 2>/dev/null || true)
  if [ -z "$PROJECT_DIR" ]; then
    echo "ERROR: Not in a git repository. Use --project-dir to specify." >&2
    exit 1
  fi
fi

PROJECT_NAME=$(basename "$PROJECT_DIR")
WORKTREE_DIR="$(dirname "$PROJECT_DIR")/${PROJECT_NAME}-${NAME}"
REGISTRY_KEY="${PROJECT_NAME}/${NAME}"

# Redirect all informational output to stderr in hook mode
log() {
  echo "$@" >&2
}

log "Creating worktree '$NAME' for project '$PROJECT_NAME'..."

# Cleanup function for error recovery
cleanup() {
  local exit_code=$?
  if [ $exit_code -ne 0 ]; then
    log "ERROR: Creation failed. Cleaning up..."

    # Stop devcontainer if started
    if [ -d "$WORKTREE_DIR/.devcontainer" ]; then
      docker compose -f "$WORKTREE_DIR/.devcontainer/docker-compose.yml" down -v 2>/dev/null || true
    fi

    # Remove worktree
    if [ -d "$WORKTREE_DIR" ]; then
      git -C "$PROJECT_DIR" worktree remove --force "$WORKTREE_DIR" 2>/dev/null || true
    fi

    # Remove branch
    git -C "$PROJECT_DIR" branch -D "$NAME" 2>/dev/null || true

    # Release ports
    "$SCRIPT_DIR/wt-port-registry" release "$REGISTRY_KEY" 2>/dev/null || true
  fi
}
trap cleanup EXIT

# Step 1: Check .devcontainer/ exists
if [ ! -d "$PROJECT_DIR/.devcontainer" ]; then
  log "ERROR: No .devcontainer/ found in $PROJECT_DIR"
  log "Each project must have its own .devcontainer/ configuration."
  exit 1
fi

# Step 2: Allocate ports (if .env.example exists)
ENV_EXAMPLE="$PROJECT_DIR/.devcontainer/.env.example"
ALLOCATED_VARS=""

if [ -f "$ENV_EXAMPLE" ]; then
  log "Allocating ports..."
  ALLOCATED_VARS=$("$SCRIPT_DIR/wt-port-registry" allocate \
    "$REGISTRY_KEY" \
    "$ENV_EXAMPLE" \
    "$PROJECT_DIR" \
    "$WORKTREE_DIR")
  log "Ports allocated."
else
  log "No .env.example found, skipping port allocation."
fi

# Step 3: Create git worktree
log "Creating git worktree..."
git -C "$PROJECT_DIR" worktree add "$WORKTREE_DIR" -b "$NAME" "$BASE_BRANCH"

# Step 4: Copy .devcontainer/ to worktree
log "Setting up devcontainer..."
cp -r "$PROJECT_DIR/.devcontainer" "$WORKTREE_DIR/.devcontainer"

# Step 5: Substitute variables in devcontainer files
if [ -n "$ALLOCATED_VARS" ]; then
  # Always set WT_NAME and COMPOSE_PROJECT_NAME
  ALLOCATED_VARS=$(printf '%s\nWT_NAME=%s\nCOMPOSE_PROJECT_NAME=%s' \
    "$ALLOCATED_VARS" \
    "${PROJECT_NAME}-${NAME}" \
    "${PROJECT_NAME}-${NAME}")

  # Generate .env file (for docker compose)
  echo "$ALLOCATED_VARS" > "$WORKTREE_DIR/.devcontainer/.env"

  # Also substitute directly in docker-compose.yml for reliability
  COMPOSE_FILE="$WORKTREE_DIR/.devcontainer/docker-compose.yml"
  if [ -f "$COMPOSE_FILE" ]; then
    while IFS='=' read -r key val; do
      [ -z "$key" ] && continue
      # Replace ${KEY:-default} patterns
      sed "s|\${${key}:-[^}]*}|${val}|g" "$COMPOSE_FILE" > "${COMPOSE_FILE}.tmp"
      mv "${COMPOSE_FILE}.tmp" "$COMPOSE_FILE"
      # Replace ${KEY} patterns
      sed "s|\${${key}}|${val}|g" "$COMPOSE_FILE" > "${COMPOSE_FILE}.tmp"
      mv "${COMPOSE_FILE}.tmp" "$COMPOSE_FILE"
    done <<< "$ALLOCATED_VARS"
  fi

  # Update devcontainer.json name
  DEVCONTAINER_JSON="$WORKTREE_DIR/.devcontainer/devcontainer.json"
  if [ -f "$DEVCONTAINER_JSON" ] && command -v jq &>/dev/null; then
    jq --arg name "${PROJECT_NAME}-${NAME}" '.name = $name' \
      "$DEVCONTAINER_JSON" > "${DEVCONTAINER_JSON}.tmp"
    mv "${DEVCONTAINER_JSON}.tmp" "$DEVCONTAINER_JSON"
  fi
fi

# Step 6: Start devcontainer
log "Starting devcontainer..."
if command -v devcontainer &>/dev/null; then
  devcontainer up --workspace-folder "$WORKTREE_DIR" >&2
  log "Devcontainer started."
else
  log "WARN: devcontainer CLI not found. Install with: npm install -g @devcontainers/cli"
  log "You can start the devcontainer manually:"
  log "  devcontainer up --workspace-folder $WORKTREE_DIR"
fi

# Step 7: Print summary
log ""
log "=== Worktree created ==="
log "  Path:    $WORKTREE_DIR"
log "  Branch:  $NAME"
if [ -n "$ALLOCATED_VARS" ]; then
  log "  Ports:"
  echo "$ALLOCATED_VARS" | grep '_PORT=' | while IFS='=' read -r key val; do
    log "    $key: $val"
  done
fi
log ""
log "Start Claude Code:"
log "  cd $WORKTREE_DIR"
log "  devcontainer exec --workspace-folder . claude --dangerously-skip-permissions"
log ""

# Output worktree path on stdout (required for Claude Code hook)
echo "$WORKTREE_DIR"
