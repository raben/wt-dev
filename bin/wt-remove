#!/usr/bin/env bash
set -euo pipefail

# wt-remove: Remove a worktree and its devcontainer
# Supports both CLI args and Claude Code hook mode (stdin JSON)

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

usage() {
  cat <<EOF
Usage: wt-remove [OPTIONS] [name]

Removes a worktree and stops its devcontainer.

Arguments:
  name          Worktree name (optional if --path is used)

Options:
  --project-dir DIR   Project root (default: git root of CWD)
  --path PATH         Worktree path (alternative to name)
  --force             Force removal even with uncommitted changes
  --hook              Read parameters from JSON stdin (Claude Code hook mode)
  -h, --help          Show help
EOF
}

# Parse arguments
HOOK_MODE=false
PROJECT_DIR=""
NAME=""
WORKTREE_PATH=""
FORCE=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --hook)        HOOK_MODE=true; shift ;;
    --project-dir) PROJECT_DIR="$2"; shift 2 ;;
    --path)        WORKTREE_PATH="$2"; shift 2 ;;
    --force)       FORCE=true; shift ;;
    -h|--help)     usage; exit 0 ;;
    -*)            echo "Unknown option: $1" >&2; usage; exit 1 ;;
    *)             NAME="$1"; shift ;;
  esac
done

# Hook mode: read from stdin
if [ "$HOOK_MODE" = true ]; then
  INPUT=$(cat)
  WORKTREE_PATH=$(echo "$INPUT" | jq -r '.worktree_path // empty')
  HOOK_CWD=$(echo "$INPUT" | jq -r '.cwd // empty')
  if [ -z "$PROJECT_DIR" ] && [ -n "$HOOK_CWD" ]; then
    PROJECT_DIR="$HOOK_CWD"
  fi
fi

# Determine project root
if [ -z "$PROJECT_DIR" ]; then
  PROJECT_DIR=$(git rev-parse --show-toplevel 2>/dev/null || true)
fi

PROJECT_NAME=""
if [ -n "$PROJECT_DIR" ]; then
  PROJECT_NAME=$(basename "$PROJECT_DIR")
fi

# Resolve worktree path and name
if [ -n "$WORKTREE_PATH" ] && [ -z "$NAME" ]; then
  # Derive name from path (last component after removing project prefix)
  local_basename=$(basename "$WORKTREE_PATH")
  if [ -n "$PROJECT_NAME" ] && [[ "$local_basename" == "${PROJECT_NAME}-"* ]]; then
    NAME="${local_basename#${PROJECT_NAME}-}"
  else
    NAME="$local_basename"
  fi
elif [ -n "$NAME" ] && [ -z "$WORKTREE_PATH" ]; then
  if [ -n "$PROJECT_DIR" ]; then
    WORKTREE_PATH="$(dirname "$PROJECT_DIR")/${PROJECT_NAME}-${NAME}"
  fi
fi

if [ -z "$NAME" ] && [ -z "$WORKTREE_PATH" ]; then
  echo "ERROR: Worktree name or --path is required" >&2
  usage >&2
  exit 1
fi

REGISTRY_KEY="${PROJECT_NAME}/${NAME}"

echo "Removing worktree '$NAME'..."

# Step 1: Check for uncommitted changes
if [ -d "$WORKTREE_PATH" ] && [ "$FORCE" = false ]; then
  if git -C "$WORKTREE_PATH" diff --quiet 2>/dev/null && \
     git -C "$WORKTREE_PATH" diff --cached --quiet 2>/dev/null; then
    : # Clean
  else
    echo "WARNING: Uncommitted changes in $WORKTREE_PATH"
    if [ -t 0 ] && [ "$HOOK_MODE" = false ]; then
      read -rp "Continue? (y/N) " confirm
      if [[ "$confirm" != [yY]* ]]; then
        echo "Aborted."
        exit 1
      fi
    else
      echo "Use --force to skip this check."
      exit 1
    fi
  fi
fi

# Step 2: Stop devcontainer
COMPOSE_FILE="$WORKTREE_PATH/.devcontainer/docker-compose.yml"
if [ -f "$COMPOSE_FILE" ]; then
  echo "Stopping devcontainer..."
  docker compose -f "$COMPOSE_FILE" down -v 2>/dev/null || true
fi

# Step 3: Remove git worktree
if [ -d "$WORKTREE_PATH" ]; then
  echo "Removing worktree..."
  if [ "$FORCE" = true ]; then
    git -C "$PROJECT_DIR" worktree remove --force "$WORKTREE_PATH" 2>/dev/null || true
  else
    git -C "$PROJECT_DIR" worktree remove "$WORKTREE_PATH" 2>/dev/null || true
  fi
fi

# Clean up stale worktree references
git -C "$PROJECT_DIR" worktree prune 2>/dev/null || true

# Step 4: Delete branch (only if merged)
if [ -n "$NAME" ] && [ -n "$PROJECT_DIR" ]; then
  if git -C "$PROJECT_DIR" branch -d "$NAME" 2>/dev/null; then
    echo "Branch '$NAME' deleted (was merged)."
  else
    echo "Branch '$NAME' not deleted (not merged or doesn't exist). Use 'git branch -D $NAME' to force."
  fi
fi

# Step 5: Release ports
if [ -n "$REGISTRY_KEY" ]; then
  "$SCRIPT_DIR/wt-port-registry" release "$REGISTRY_KEY" 2>/dev/null || true
fi

echo "Worktree '$NAME' removed."
